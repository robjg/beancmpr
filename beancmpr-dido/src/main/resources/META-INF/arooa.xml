<arooa:descriptor xmlns:arooa="http://rgordon.co.uk/oddjob/arooa"
  prefix="didocmpr" namespace="oddjob:didocmpr">
  <conversions>
    <arooa:conversion className="org.oddjob.beancmpr.continuous.SourceStrategies"
                      methodName="toSourceStrategy"
                      arooaValue="true"/>
  </conversions>
  <values>
    <arooa:bean-def element='collection-comparer'
      className='beancmpr.dido.beans.IterableDataComparerType'
      designFactory='org.oddjob.beancmpr.beans.IterableBeansComparerDF'>
      <properties>
        <arooa:property name="keys" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="values" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="others" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
      </properties>
    </arooa:bean-def>
    <arooa:bean-def element='continuous-strategy'
                    className='org.oddjob.beancmpr.continuous.SourceStrategies'>
    </arooa:bean-def>
    <arooa:bean-def element='data-results'
                    className='beancmpr.dido.results.GenericDataResultHandlerFactory'>
    </arooa:bean-def>
  </values>
  <components>
    <arooa:bean-def element='continuous-comparer'
                    className='beancmpr.dido.continuous.DataCompareService'>
      <properties>
        <arooa:property name="keys" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="values" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="others" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="tolerance" annotation="org.oddjob.arooa.deploy.annotations.ArooaAttribute"/>
        <arooa:property name="to" annotation="org.oddjob.beanbus.Destination"/>
      </properties>
      <annotations>
        <arooa:annotation name="org.oddjob.framework.adapt.SoftReset"
                          method="reset" />
        <arooa:annotation name="org.oddjob.framework.adapt.HardReset"
                          method="reset" />
        <arooa:annotation name="org.oddjob.framework.adapt.AcceptExceptionListener"
                          method="exceptionListener"
                          parameterTypes="java.beans.ExceptionListener"/>
      </annotations>
    </arooa:bean-def>
  </components>
</arooa:descriptor>